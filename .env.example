# Turnitout Environment Configuration
# Place this file in the project root directory (adjacent to run.py).
# It allows adjusting the pipeline's behavior without editing configurations or code.

# ==============================================================================
# 1. SYNONYM AGGRESSIVENESS (TURNITOUT_AGGRESSIVENESS)
# ==============================================================================
# Controls the probability that a prose word will be replaced by a synonym
# from the rules dictionary.
#
# How to adjust:
#   - Set higher (e.g., 0.85 to 0.95) for maximum vocabulary diversity.
#     Note: Very high values may occasionally sound slightly less natural.
#   - Set lower (e.g., 0.40 to 0.60) to keep more of the original text's flow
#     while still introducing stylistic variation.
#   - Value must be a decimal (float) between 0.0 (0% swaps) and 1.0 (100% swaps).
# Default: 0.75
TURNITOUT_AGGRESSIVENESS=0.75

# ==============================================================================
# 2. MINIMUM SENTENCE LENGTH FOR CITATION (TURNITOUT_MIN_SENTENCE_LEN)
# ==============================================================================
# Sets the threshold (in characters) for a sentence to qualify for an appended 
# bibliography citation (\cite{...}) when scientific keywords are matched.
#
# How to adjust:
#   - Set higher (e.g., 60 to 80 characters) to ensure only long, complex
#     academic sentences receive citations, keeping headers and short statements
#     uncluttered.
#   - Set lower (e.g., 30 to 40 characters) if the document has short sentences
#     and more citation density is needed to satisfy academic reference requirements.
# Default: 45
TURNITOUT_MIN_SENTENCE_LEN=45

# ==============================================================================
# 3. REPRODUCIBILITY SEED (TURNITOUT_RANDOM_SEED)
# ==============================================================================
# Seed value used to initialize the random number generator. 
#
# How to adjust:
#   - Keep the same (e.g., 42) to guarantee that running the tool on the same
#     input file yields the exact same synonym replacements and formatting outputs.
#   - Change to any other integer (e.g., 100, 777) to produce a different random
#     permutation of synonym choices for the same document.
# Default: 42
TURNITOUT_RANDOM_SEED=42

# ==============================================================================
# 4. VOICE TRANSFORMATION (TURNITOUT_VOICE_TRANSFORM, TURNITOUT_VOICE_RATE)
# ==============================================================================
# Alternates active/passive constructions to prevent voice monotony.
# In active-to-passive, "We analyzed the results" -> "The results were analyzed."
# In passive-to-active, "The method was applied by researchers" -> "Researchers applied the method."
#
# How to adjust:
#   - Set TURNITOUT_VOICE_TRANSFORM to true/false to enable/disable the stage.
#   - Set TURNITOUT_VOICE_RATE (decimal 0.0 to 1.0) to control the fire rate.
#     Set higher (e.g., 0.60 to 0.80) to aggressively alternate voices.
#     Set lower (e.g., 0.15 to 0.30) to preserve more of the original voice.
#     Only targets sentences with length >= 60 characters and no LaTeX placeholders.
# Defaults: true, 0.30
TURNITOUT_VOICE_TRANSFORM=true
TURNITOUT_VOICE_RATE=0.30

# ==============================================================================
# 5. SENTENCE FUSION (TURNITOUT_SENTENCE_FUSION, TURNITOUT_FUSION_RATE)
# ==============================================================================
# Combines two short adjacent sentences to vary rhythmic length.
# "The temperature increased. This caused expansion." -> "The temperature increased, which consequently caused expansion."
#
# How to adjust:
#   - Set TURNITOUT_SENTENCE_FUSION to true/false to enable/disable the stage.
#   - Set TURNITOUT_FUSION_RATE (decimal 0.0 to 1.0) to control the fire rate.
#     Set higher (e.g., 0.50 to 0.70) to merge adjacent short sentences more frequently,
#     creating longer, complex clauses that enhance sentence-length variation.
#     Set lower (e.g., 0.15 to 0.25) to preserve the original sentence boundaries.
# Defaults: true, 0.25
TURNITOUT_SENTENCE_FUSION=true
TURNITOUT_FUSION_RATE=0.25

# ==============================================================================
# 6. TRANSITION PHRASE INJECTION (TURNITOUT_TRANSITION_INJECT, TURNITOUT_TRANSITION_RATE)
# ==============================================================================
# Enriches logical connectors to add coherence and avoid repetition.
# Inserts categorized transition phrases (Contrast, Cause/Effect, Addition, etc.) 
# at sentence starts or after commas, maintaining a history of recently used 
# transitions to avoid repetitive patterns.
#
# How to adjust:
#   - Set TURNITOUT_TRANSITION_INJECT to true/false to enable/disable the stage.
#   - Set TURNITOUT_TRANSITION_RATE (decimal 0.0 to 1.0) to control the fire rate.
#     Set higher (e.g., 0.50 to 0.70) to maximize transition diversity.
#     Set lower (e.g., 0.15 to 0.30) to inject transitions sparingly.
#     Only targets sentences with length >= 70 characters and no LaTeX placeholders.
# Defaults: true, 0.25
TURNITOUT_TRANSITION_INJECT=true
TURNITOUT_TRANSITION_RATE=0.25

# ==============================================================================
# 7. CLAUSE WORD REORDERING (TURNITOUT_WORD_REORDER, TURNITOUT_REORDER_RATE)
# ==============================================================================
# Rearranges prepositional phrases and adverbial modifiers within clauses.
# "In this chapter, we present the results..." -> "We present, in this chapter, the results..."
#
# How to adjust:
#   - Set TURNITOUT_WORD_REORDER to true/false to enable/disable the stage.
#   - Set TURNITOUT_REORDER_RATE (decimal 0.0 to 1.0) to control the fire rate.
#     Set higher (e.g., 0.50 to 0.70) to aggressively shift clauses.
#     Set lower (e.g., 0.10 to 0.25) to preserve the original clause order.
#     Only targets sentences with length >= 80 characters and no LaTeX placeholders.
# Defaults: true, 0.20
TURNITOUT_WORD_REORDER=true
TURNITOUT_REORDER_RATE=0.20

# ==============================================================================
# 8. NOMINALIZATION (TURNITOUT_NOMINALIZATION, TURNITOUT_NOMINAL_RATE)
# ==============================================================================
# Alternates verbal and nominal forms to modulate stylistic register.
# Verb -> Noun: "We investigated the phenomenon" -> "An investigation of the phenomenon was conducted."
# Noun -> Verb: "The application of the method" -> "Applying the method."
#
# How to adjust:
#   - Set TURNITOUT_NOMINALIZATION to true/false to enable/disable the stage.
#   - Set TURNITOUT_NOMINAL_RATE (decimal 0.0 to 1.0) to control the fire rate.
#     Set higher (e.g., 0.40 to 0.60) to aggressively alternate nominal structures.
#     Set lower (e.g., 0.15 to 0.25) to leave verb/noun constructs unchanged.
#     Only targets sentences with length >= 70 characters and no LaTeX placeholders.
# Defaults: true, 0.20
TURNITOUT_NOMINALIZATION=true
TURNITOUT_NOMINAL_RATE=0.20

# ==============================================================================
# 9. APPOSITIVE INJECTION (TURNITOUT_APPOSITIVE, TURNITOUT_APPOSITIVE_RATE)
# ==============================================================================
# Injects brief parenthetical definitions after key technical terms.
# "The Crank-Nicolson method" -> "The Crank-Nicolson method, an implicit second-order-accurate scheme,"
#
# How to adjust:
#   - Set TURNITOUT_APPOSITIVE to true/false to enable/disable the stage.
#   - Set TURNITOUT_APPOSITIVE_RATE (decimal 0.0 to 1.0) to control the fire rate.
#     Set higher (e.g., 0.50 to 0.70) to maximize clarifying descriptions.
#     Set lower (e.g., 0.20 to 0.40) to keep definition insertions sparse.
#     Each appositive term is guaranteed to be injected only once per document.
# Defaults: true, 0.35
TURNITOUT_APPOSITIVE=true
TURNITOUT_APPOSITIVE_RATE=0.35

# ==============================================================================
# 10. DISCOURSE MARKER ROTATION (TURNITOUT_DISCOURSE_ROTATE, TURNITOUT_DISCOURSE_RATE)
# ==============================================================================
# Replaces overused linking words/discourse markers with varied equivalents.
# "However" -> ["Nevertheless", "Nonetheless", "On the other hand", "That said", "Be that as it may"]
#
# How to adjust:
#   - Set TURNITOUT_DISCOURSE_ROTATE to true/false to enable/disable the stage.
#   - Set TURNITOUT_DISCOURSE_RATE (decimal 0.0 to 1.0) to control the fire rate.
#     Set higher (e.g., 0.70 to 0.90) to ensure linking words are rotated consistently.
#     Set lower (e.g., 0.30 to 0.50) to retain original discourse markers.
#     Guarantees never using the same replacement twice for a marker in a document.
# Defaults: true, 0.50
TURNITOUT_DISCOURSE_ROTATE=true
TURNITOUT_DISCOURSE_RATE=0.50

# ==============================================================================
# 11. CONTRACTION CONVERSION (TURNITOUT_CONTRACTION, TURNITOUT_CONTRACTION_RATE)
# ==============================================================================
# Swaps formal word groups to contractions and vice versa contextually.
# "cannot" <-> "can't", "is not" <-> "isn't", "does not" <-> "doesn't"
# Swapping both ways increases perplexity and variation for AI detectors
# while a low rate (e.g., 0.20) maintains a highly professional academic look.
#
# How to adjust:
#   - Set TURNITOUT_CONTRACTION to true/false to enable/disable the stage.
#   - Set TURNITOUT_CONTRACTION_RATE (decimal 0.0 to 1.0) to control the fire rate.
#     Set higher (e.g., 0.40 to 0.60) to increase contractions for aggressive AI defense.
#     Set lower (e.g., 0.10 to 0.25) to preserve the original formal style.
# Defaults: true, 0.20
TURNITOUT_CONTRACTION=true
TURNITOUT_CONTRACTION_RATE=0.20

# ==============================================================================
# 12. SOURCE-AWARE N-GRAM AUDIT (TURNITOUT_NGRAM_AUDIT)
# ==============================================================================
# Scans the final output document for any remaining 5-gram matches from the original 
# source document and dynamically disrupts them using synonyms or inserted adverbs.
# Defaults: true
TURNITOUT_NGRAM_AUDIT=true

# ==============================================================================
# 13. RISK-DRIVEN CITATION SHIELDING (TURNITOUT_RISK_CITATION)
# ==============================================================================
# Prioritizes placing bibliography citations directly at overlapping n-gram boundaries
# to act as a mathematical "shield" that breaks the rolling hash sequence.
# Defaults: true
TURNITOUT_RISK_CITATION=true
