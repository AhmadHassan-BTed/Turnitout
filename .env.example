# Turnitout Environment Configurations
# Copy this file to '.env' in the project root to override default settings

# Synonym aggressiveness (float value between 0.0 and 1.0)
# Higher values replace more words with academic synonyms.
TURNITOUT_AGGRESSIVENESS=0.75

# Minimum sentence length for citation insertion (integer)
# Sentences shorter than this length will not be appended with citations.
TURNITOUT_MIN_SENTENCE_LEN=45

# Random seed (integer)
# Ensures reproducibility across pipeline runs.
TURNITOUT_RANDOM_SEED=42
